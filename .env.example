# Copy to .env and fill in. .env is gitignored.

# ---- OpenAI (gmail-sync classification) ----
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ---- Gmail (gmail_sync.py) ----
# Local dev:
#   1) Create Google Cloud project, enable Gmail API.
#   2) Create OAuth client (Desktop). Download as credentials.json to repo root.
#   3) Run: python gmail_sync.py --auth
#   This writes token.json.
#
# Railway deploy:
#   Set GMAIL_TOKEN_B64 to: base64 -i token.json
GMAIL_TOKEN_B64=
GMAIL_POLL_INTERVAL=900

# ---- Telegram bot ----
# Create bot via @BotFather, paste token here.
TELEGRAM_BOT_TOKEN=
# Optional allowlist — comma-separated numeric Telegram user IDs. Empty = open.
TELEGRAM_ALLOWED_USER_IDS=

# ---- OpenAI (GPT-4o — used by some career-ops scripts) ----
OPENAI_API_KEY=
